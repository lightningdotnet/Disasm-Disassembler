# Default: text auto-detect, normalise to LF in repo
* text=auto eol=lf

# Source — explicit
*.c        text eol=lf
*.cpp      text eol=lf
*.h        text eol=lf
*.hpp      text eol=lf
*.cmake    text eol=lf
CMakeLists.txt  text eol=lf

# Project files / docs
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf

# Windows scripts that genuinely need CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary
*.exe      binary
*.dll      binary
*.lib      binary
*.pdb      binary
*.obj      binary
*.ttf      binary
*.otf      binary
*.ico      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
